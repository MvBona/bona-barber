# =============================================
# Baileys — WhatsApp (conexão direta via QR Code)
# Sem credenciais necessárias — sessão salva em disco
# Na primeira execução: escanear QR Code que aparece no terminal
# =============================================
BAILEYS_AUTH_FOLDER=auth_info_baileys

# =============================================
# Google Sheets — Agenda
# Criar planilha com a estrutura do projeto
# Compartilhar com o e-mail da service account
# =============================================
SPREADSHEET_ID=

# =============================================
# Google Service Account — Credenciais JSON
# Criar em: https://console.cloud.google.com
# Copiar o conteúdo do JSON em uma linha só
# =============================================
GOOGLE_CREDENTIALS=

# =============================================
# OpenAI — Transcrição de áudio (Whisper)
# Obter em: https://platform.openai.com/api-keys
# =============================================
OPENAI_API_KEY=

# =============================================
# Anthropic — Interpretação de texto (Claude)
# Obter em: https://console.anthropic.com/settings/keys
# =============================================
ANTHROPIC_API_KEY=

# =============================================
# Configurações da barbearia
# =============================================
BARBERSHOP_NAME=Nome da Barbearia
BOT_NAME=Fio
BARBERSHOP_OPEN=10:00
BARBERSHOP_CLOSE=20:00
BARBERSHOP_SLOT_DURATION=60
BARBERSHOP_TIMEZONE=America/Sao_Paulo

# Número do barbeiro no formato internacional sem + (ex: 5511999999999)
BARBERSHOP_PHONE=
# JID do barbeiro no WhatsApp (aparece nos logs na primeira mensagem recebida)
# Ex: 5511999999999@s.whatsapp.net ou 66688628297913@lid
BARBERSHOP_JID=
